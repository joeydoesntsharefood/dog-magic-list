{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "allowJs": true,
    "types": ["node", "electron"],
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "../db/src/**/*"]
}