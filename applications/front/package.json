{
  "name": "front",
  "description": "DogMagic List - Deck Construction Wizard",
  "author": "Mateus <mateus@example.com>",
  "homepage": "https://github.com/example/dogmagic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --no-open",
    "dev:electron": "wait-on http://localhost:5173 && tsc electron/main.ts electron/preload.ts --outDir electron --module commonjs --target esnext --allowJs true --skipLibCheck true && mv electron/main.js electron/main.cjs && mv electron/preload.js electron/preload.cjs && electron electron/main.cjs",
    "build:back": "node build-back.js",
    "build": "tsc && vite build && npm run build:back && electron-builder --linux",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.dogmagic.app",
    "productName": "DogMagic",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "dist-back",
        "to": "backend"
      },
      {
        "from": ".puppeteer",
        "to": ".puppeteer"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.8.2",
    "kysely": "^0.28.11",
    "puppeteer": "^24.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.3",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.7",
    "wait-on": "^8.0.2"
  }
}
